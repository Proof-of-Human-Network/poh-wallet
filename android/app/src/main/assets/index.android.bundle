","settings.lang_title":"Language","settings.lang_desc":"Choose your preferred language. Changes apply instantly.","lang.current":"Current","alert.close":"Close","alert.copy":"Copy (manual)","alert.your_address":"Your Address","alert.cancel":"Cancel","alert.copied":"Copied","alert.pk_copied":"Private key copied to clipboard. Save it securely now!","alert.pk_copied_short":"Private key copied to clipboard. Store it securely!","create.warning_title":"\u26a0\ufe0f SAVE YOUR PRIVATE KEY NOW","create.warning_body":"Address:\n{{address}}\n\nPRIVATE KEY:\n{{privateKey}}\n\nTHIS IS THE ONLY TIME this private key will be shown without extra confirmation.\n\nYou can view it again later from the Wallets screen, but it will require explicit confirmation each time.\n\nIf you lose this key, you will permanently lose access to your POH funds.\n\nCopy it now and save it in a secure offline location.","create.copy_pk":"Copy Private Key","create.saved_pk":"I've Saved the Private Key","create.created_title":"Wallet Created","create.created_body":"Address:\n{{address}}\n\nYour private key is stored securely on this device.\n\nYou can view it again later from the Wallets screen (with security warnings).\n\nTo use this wallet from a miner node, import the same private key using the CLI on that machine.","create.error_save":"Error saving wallet","create.error":"Error creating wallet","reveal.title":"Reveal Private Key?","reveal.body":"This is a sensitive action.\n\nThe private key gives full control over this wallet and its funds.\nOnly reveal it in a private, trusted environment.\n\nAre you sure you want to view it now?","reveal.yes":"Yes, Show Private Key","reveal.secret_title":"Private Key - Keep This Secret","reveal.secret_body":"Address:\n{{address}}\n\nPRIVATE KEY:\n{{privateKey}}\n\n\u26a0\ufe0f NEVER share this key with anyone.\nAnyone who has this key can take all your POH.","reveal.error_not_found":"Private key not found for this wallet.","reveal.error":"Failed to retrieve private key.","import.error_invalid":"Enter a valid private key (hex, 64+ chars recommended)","import.already":"Already imported","import.already_body":"This private key is already in your wallet list.","import.success_title":"Wallet Imported","import.success_body":"Address: {{address}}","import.failed":"Import failed","send.error_invalid":"Enter a valid recipient address and amount","send.no_wallet":"No wallet selected","send.insufficient":"Insufficient balance","send.failed_title":"Send Failed","send.failed_tip":"{{msg}}\n\nTip: For demo transfers, the sending address must exist in the node's ~/.poh-miner/wallets folder. Use the CLI on that machine:\n  poh-miner wallet create\nThen paste the private key from this device.","send.success_title":"Sent","send.success_body":"{{amount}} POH sent to {{to}}","send.network_error":"Could not reach the node. Check Settings > Nodes.","notif.tx_sent_title":"Transaction Sent","notif.tx_sent_body":"{{amount}} POH \u2192 {{to}}...","notif.received_title":"POH Received","notif.received_body":"+{{delta}} POH to {{addr}}...","notif.created_title":"Wallet Created","notif.created_body":"New address: {{addr}}...","notif.imported_title":"Wallet Imported","notif.imported_body":"{{addr}}...",error:"Error","error.network":"Network Error","status.confirmed":"confirmed"},fr:{"app.title":"Portefeuille POH","nav.settings":"Param\xe8tres","tab.home":"Accueil","tab.send":"Envoyer","tab.receive":"Recevoir","tab.history":"Historique","tab.wallets":"Portefeuilles","tab.search":"Recherche","home.balance":"Solde","home.no_wallet":"Aucun portefeuille","home.last_sync":"Derni\xe8re synchronisation","home.recent_activity":"Activit\xe9 r\xe9cente","home.refresh":"Actualiser","home.no_tx":"Aucune transaction","home.manage_wallets":"G\xe9rer les portefeuilles ({{count}})","action.receive":"Recevoir","action.send":"Envoyer","send.title":"Envoyer POH","send.from":"De","send.recipient_placeholder":"Adresse du destinataire (poh...)","send.amount_placeholder":"Montan
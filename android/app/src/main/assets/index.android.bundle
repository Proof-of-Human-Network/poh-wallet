\u10d0\u10dc\u10d4\u10d1\u10d8\u10d7 \u10e8\u10d4\u10d2\u10d8\u10eb\u10da\u10d8\u10d0\u10d7 \u10dc\u10d0\u10ee\u10dd\u10d7 \u10e1\u10d0\u10e4\u10e3\u10da\u10d4\u10d4\u10d1\u10d8\u10e1 \u10d4\u10d9\u10e0\u10d0\u10dc\u10d8\u10d3\u10d0\u10dc, \u10db\u10d0\u10d2\u10e0\u10d0\u10db \u10e7\u10dd\u10d5\u10d4\u10da \u10ef\u10d4\u10e0\u10d6\u10d4 \u10d3\u10d0\u10d2\u10ed\u10d8\u10e0\u10d3\u10d4\u10d1\u10d0\u10d7 \u10d0\u10e8\u10d9\u10d0\u10e0\u10d0 \u10d3\u10d0\u10d3\u10d0\u10e1\u10e2\u10e3\u10e0\u10d4\u10d1\u10d0.\n\n\u10d7\u10e3 \u10d3\u10d0\u10d9\u10d0\u10e0\u10d2\u10d0\u10d5\u10d7 \u10d0\u10db \u10d2\u10d0\u10e1\u10d0\u10e6\u10d4\u10d1\u10e1, \u10e1\u10d0\u10db\u10e3\u10d3\u10d0\u10db\u10dd\u10d3 \u10d3\u10d0\u10d9\u10d0\u10e0\u10d2\u10d0\u10d5\u10d7 \u10d7\u10e5\u10d5\u10d4\u10dc\u10e1 POH \u10e1\u10d0\u10ee\u10e1\u10e0\u10d4\u10d1\u10e1.\n\n\u10d3\u10d0\u10e3\u10e7\u10dd\u10d5\u10dc\u10d4\u10d1\u10da\u10d8\u10d5 \u10d3\u10d0\u10d0\u10d9\u10dd\u10de\u10d8\u10e0\u10d4\u10d7 \u10d3\u10d0 \u10e8\u10d4\u10d8\u10dc\u10d0\u10ee\u10d4\u10d7 \u10e3\u10e1\u10d0\u10e4\u10e0\u10d7\u10ee\u10dd \u10dd\u10e4\u10da\u10d0\u10d8\u10dc \u10d0\u10d3\u10d2\u10d8\u10da\u10d0\u10e1.","create.copy_pk":"\u10de\u10d8\u10e0\u10d0\u10d3\u10d8 \u10d2\u10d0\u10e1\u10d0\u10e6\u10d4\u10d1\u10d8\u10e1 \u10d9\u10dd\u10de\u10d8\u10e0\u10d4\u10d1\u10d0","create.saved_pk":"\u10db\u10d4 \u10e8\u10d4\u10d5\u10d8\u10dc\u10d0\u10ee\u10d4 \u10de\u10d8\u10e0\u10d0\u10d3\u10d8 \u10d2\u10d0\u10e1\u10d0\u10e6\u10d4\u10d1\u10d8","create.created_title":"\u10e1\u10d0\u10e4\u10e3\u10da\u10d4 \u10e8\u10d4\u10d8\u10e5\u10db\u10dc\u10d0","create.created_body":"\u10db\u10d8\u10e1\u10d0\u10db\u10d0\u10e0\u10d7\u10d8:\n{{address}}\n\n\u10d7\u10e5\u10d5\u10d4\u10dc\u10d8 \u10de\u10d8\u10e0\u10d0\u10d3\u10d8 \u10d2\u10d0\u10e1\u10d0\u10e6\u10d4\u10d1\u10d8 \u10e3\u10e1\u10d0\u10e4\u10e0\u10d7\u10ee\u10dd\u10d3 \u10d8\u10dc\u10d0\u10ee\u10d4\u10d1\u10d0 \u10d0\u10db \u10db\u10dd\u10ec\u10e7\u10dd\u10d1\u10d8\u10da\u10dd\u10d1\u10d0\u10d6\u10d4.\n\n\u10db\u10dd\u10d2\u10d5\u10d8\u10d0\u10dc\u10d4\u10d1\u10d8\u10d7 \u10e8\u10d4\u10d2\u10d8\u10eb\u10da\u10d8\u10d0\u10d7 \u10dc\u10d0\u10ee\u10dd\u10d7 \u10e1\u10d0\u10e4\u10e3\u10da\u10d4\u10d4\u10d1\u10d8\u10e1 \u10d4\u10d9\u10e0\u10d0\u10dc\u10d8\u10d3\u10d0\u10dc (\u10e3\u10e1\u10d0\u10e4\u10e0\u10d7\u10ee\u10dd\u10d4\u10d1\u10d8\u10e1 \u10d2\u10d0\u10e4\u10e0\u10d7\u10ee\u10d8\u10da\u10d4\u10d1\u10d4\u10d1\u10d8\u10d7).\n\n\u10d0\u10db \u10e1\u10d0\u10e4\u10e3\u10da\u10d8\u10e1 \u10db\u10d0\u10d8\u10dc\u10d4\u10e0 \u10d9\u10d5\u10d0\u10dc\u10eb\u10d6\u10d4 \u10d2\u10d0\u10db\u10dd\u10e1\u10d0\u10e7\u10d4\u10dc\u10d4\u10d1\u10da\u10d0\u10d3, \u10d8\u10db\u10de\u10dd\u10e0\u10e2\u10d8\u10e0\u10d4\u10d7 \u10d8\u10d2\u10d8\u10d5\u10d4 \u10de\u10d8\u10e0\u10d0\u10d3\u10d8 \u10d2\u10d0\u10e1\u10d0\u10e6\u10d4\u10d1\u10d8 CLI-\u10d8\u10d7 \u10d8\u10db \u10db\u10d0\u10dc\u10e5\u10d0\u10dc\u10d0\u10d6\u10d4.","create.error_save":"\u10e1\u10d0\u10e4\u10e3\u10da\u10d8\u10e1 \u10e8\u10d4\u10dc\u10d0\u10ee\u10d5\u10d8\u10e1 \u10e8\u10d4\u10ea\u10d3\u10dd\u10db\u10d0","create.error":"\u10e1\u10d0\u10e4\u10e3\u10da\u10d8\u10e1 \u10e8\u10d4\u10e5\u10db\u10dc\u10d8\u10e1 \u10e8\u10d4\u10ea\u10d3\u10dd\u10db\u10d0","reveal.title":"\u10de\u10d8\u10e0\u10d0\u10d3\u10d8 \u10d2\u10d0\u10e1\u10d0\u10e6\u10d4\u10d1\u10d8\u10e1 \u10d2\u10d0\u10db\u10df\u10e6\u10d0\u10d5\u10dc\u10d4\u10d1\u10d0?","reveal.body":"\u10d4\u10e1 \u10d0\u10e0\u10d8\u10e1 \u10db\u10d2\u10e0\u10eb\u10dc\u10dd\u10d1\u10d8\u10d0\u10e0\u10d4 \u10db\u10dd\u10e5\u10db\u10d4\u10d3\u10d4\u10d1\u10d0.\n\n\u10de\u10d8\u10e0\u10d0\u10d3\u10d8 \u10d2\u10d0\u10e1\u10d0\u10e6\u10d4\u10d1\u10d8 \u10d8\u10eb\u10da\u10d4\u10d5\u10d0 \u10e1\u10e0\u10e3\u10da \u10d9\u10dd\u10dc\u10e2\u10e0\u10dd\u10da\u10e1 \u10d0\u10db \u10e1\u10d0\u10e4\u10e3\u10da\u10d4\u10d6\u10d4 \u10d3\u10d0 \u10db\u10d8\u10e1 \u10e1\u10d0\u10ee\u10e1\u10e0\u10d4\u10d1\u10d6\u10d4.\n\u10d2\u10d0\u10db\u10dd\u10d0\u10d5\u10da\u10d8\u10dc\u10d4\u10d7 \u10d8\u10e1 \u10db\u10ee\u10dd\u10da\u10dd\u10d3 \u10d9\u10d4\u10e0\u10eb\u10dd, \u10e1\u10d0\u10dc\u10d3\u10dd \u10d2\u10d0\u10e0\u10d4\u10db\u10dd\u10e8\u10d8.\n\n\u10d3\u10d0\u10e0\u10ec\u10db\u10e3\u10dc\u10d4\u10d1\u10e3\u10da\u10d8 \u10ee\u10d0\u10e0\u10d7, \u10e0\u10dd\u10db \u10d2\u10e1\u10e3\u10e0\u10d7 \u10db\u10d8\u10e1\u10d8 \u10dc\u10d0\u10ee\u10d5\u10d0 \u10d0\u10ee\u10da\u10d0?","reveal.yes":"\u10d3\u10d8\u10d0\u10ee, \u10de\u10d8\u10e0\u10d0\u10d3\u10d8 \u10d2\u10d0\u10e1\u10d0\u10e6\u10d4\u10d1\u10d8\u10e1 \u10e9\u10d5\u10d4\u10dc\u10d4\u10d1\u10d0","reveal.secret_title":"\u10de\u10d8\u10e0\u10d0\u10d3\u10d8 \u10d2\u10d0\u10e1\u10d0\u10e6\u10d4\u10d1\u10d8 - \u10e8\u10d4\u10d8\u10dc\u10d0\u10ee\u10d4\u10d7 \u10e1\u10d0\u10d8\u10d3\u10e3\u10db\u10da\u10dd\u10d3","reveal.secret_body":"\u10db\u10d8\u10e1\u10d0\u10db\u10d0\u10e0\u10d7\u10d8:\n{{address}}\n\n\u10de\u10d8\u10e0\u10d0\u10d3\u10d8 \u10d2\u10d0\u10e1\u10d0\u10e6\u10d4\u10d1\u10d8:\n{{privateKey}}\n\n\u26a0\ufe0f \u10d0\u10e0\u10d0\u10e1\u10dd\u10d3\u10d4\u10e1 \u10d2\u10d0\u10e3\u10d6\u10d8\u10d0\u10e0\u10dd\u10d7 \u10d4\u10e1 \u10d2\u10d0\u10e1\u10d0\u10e6\u10d4\u10d1\u10d8 \u10d5\u10d8\u10dc\u10db\u10d4\u10e1.\n\u10dc\u10d4\u10d1\u10d8\u10e1\u10db\u10d8\u10d4\u10e0\u10e1, \u10d5\u10d8\u10e1\u10d0\u10ea \u10d4\u10e1 \u10d2\u10d0\u10e1\u10d0\u10e6\u10d4\u10d1\u10d8 \u10d0\u10e5\u10d5\u10e1, \u10e8\u10d4\u10e3\u10eb\u10da\u10d8\u10d0 \u10ec\u10d0\u10d8\u10e6\u10dd\u10e1 \u10e7\u10d5\u10d4\u10da\u10d0 \u10d7\u10e5\u10d5\u10d4\u10dc\u10d8 POH.","reveal.error_not_found":"\u10d0\u10db \u10e1\u10d0\u10e4\u10e3\u10da\u10d8\u10e1\u10d7\u10d5\u10d8\u10e1 \u10de\u10d8\u10e0\u10d0\u10d3\u10d8 \u10d2\u10d0\u10e1\u10d0\u10e6\u10d4\u10d1\u10d8 \u10d5\u10d4\u10e0 \u10db\u10dd\u10d8\u10eb\u10d4\u10d1\u10dc\u10d0.","reveal.error":"\u10de\u10d8\u10e0\u10d0\u10d3\u10d8 \u10d2\u10d0\u10e1\u10d0\u10e6\u10d4\u10d1\u10d8\u10e1 \u10db\u10d8\u10e6\u10d4\u10d1\u10d0 \u10d5\u10d4\u10e0 \u10db\u10dd\u10ee\u10d4\u10e0\u10ee\u10d3\u10d0.","import.error_invalid":"\u10e8\u10d4\u10d8\u10e7\u10d5\u10d0\u10dc\u10d4\u10d7 \u10e1\u10ec\u10dd\u10e0\u10d8 \u10de\u10d8\u10e0\u10d0\u10d3\u10d8 \u10d2\u10d0\u10e1\u10d0\u10e6\u10d4\u10d1\u10d8 (hex, \u10e0\u10d4\u10d9\u10dd\u10db\u10d4\u10dc\u10d3\u10d4\u10d1\u10e3\u10da\u10d8\u10d0 64+ \u10e1\u10d8\u10db\u10d1\u10dd\u10da\u10dd)","import.already":"\u10e3\u10d9\u10d5\u10d4 \u10d8\u10db\u10de\u10dd\u10e0\u10e2\u10d8\u10e0\u10d4\u10d1\u10e3\u10da\u10d8\u10d0","import.already_body":"\u10d4\u10e1 \u10de\u10d8\u10e0\u10d0\u10d3\u10d8 \u10d2\u10d0\u10e1\u10d0\u10e6\u10d4\u10d1\u10d8 \u10e3\u10d9\u10d5\u10d4 \u10d7\u10e5\u10d5\u10d4\u10dc\u10e1 \u10e1\u10d0\u10e4\u10e3\u10da\u10d4\u10d4\u10d1\u10d8\u10e1 \u10e1\u10d8\u10d0\u10e8\u10d8\u10d0.","import.success_title":"\u10e1\u10d0\u10e4\u10e3\u10da\u10d4 \u10d8\u10db\u10de\u10dd\u10e0\u10e2\u10d8\u10e0\u10d4\u10d1\u10e3\u10da\u10d8\u10d0","import.success_body":"\u10db\u10d8\u10e1\u10d0\u10db\u10d0\u10e0\u10d7\u10d8: {{address}}","import.failed":"\u10d8\u10db\u10de\u10dd\u10e0\u10e2\u10d8 \u10d5\u10d4\u10e0 \u10db\u10dd\u10ee\u10d4\u10e0\u10ee\u10d3\u10d0","send.error_invalid":"\u10e8\u10d4\u10d8\u10e7\u10d5\u10d0\u10dc\u10d4\u10d7 \u10e1\u10ec\u10dd\u10e0\u10d8 \u10db\u10d8\u10db\u10e6\u10d4\u10d1\u10d8\u10e1 \u10db\u10d8\u10e1\u10d0\u10db\u10d0\u10e0\u10d7\u10d8 \u10d3\u10d0 \u10d7\u10d0\u10dc\u10ee\u10d0","send.no_wallet":"\u10e1\u10d0\u10e4\u10e3\u10da\u10d4 \u10d0\u10e0 \u10d0\u10e0\u10d8\u10e1 \u10d0\u10e0\u10e9\u10d4\u10e3\u10da\u10d8","send.insufficient":"\u10d0\u10e0\u10d0\u10e1\u10d0\u10d9\u10db\u10d0\u10e0\u10d8\u10e1\u10d8 \u10d1\u10d0\u10da\u10d0\u10dc\u10e1\u10d8","send.failed_title":"\u10d2\u10d0\u10d2\u10d6\u10d0\u10d5\u10dc\u10d0 \u10d5\u10d4\u10e0 \u10db\u10dd\u10ee\u10d4\u10e0\u10ee\u10d3\u10d0","send.failed_tip":"{{msg}}\n\n\u10e0\u10e9\u10d4\u10d5\u10d0: \u10e1\u10d0\u10e9\u10d5\u10d4\u10dc\u10d4\u10d1\u10d4\u10da\u10d8 \u10d2\u10d0\u10d3\u10d0\u10e0\u10d8\u10ea\u10ee\u10d5\u10d4\u10d1\u10d8\u10e1\u10d7\u10d5\u10d8\u10e1, \u10d2\u10d0\u10db\u10d2\u10d6\u10d0\u10d5\u10dc\u10d8\u10e1 \u10db\u10d8\u10e1\u10d0\u10db\u10d0\u10e0\u10d7\u10d8 \u10e3\u10dc\u10d3\u10d0 \u10d0\u10e0\u10e1\u10d4\u10d1\u10dd\u10d1\u10d3\u10d4\u10e1 \u10d9\u10d5\u10d0\u10dc\u10eb\u10d8\u10e1 ~/.poh-miner/wallets \u10e1\u10d0\u10e5\u10d0\u10e6\u10d0\u10da\u10d3\u10d4\u10e8\u10d8. \u10d2\u10d0\u10db\u10dd\u10d8\u10e7\u10d4\u10dc\u10d4\u10d7 CLI \u10d8\u10db \u10db\u10d0\u10dc\u10e5\u10d0\u10dc\u10d0\u10d6\u10d4.","send.success_title":"\u10d2\u10d0\u10d2\u10d6\u10d0\u10d5\u10dc\u10d8\u10da\u10d8\u10d0","send.success_body":"{{amount}} POH \u10d2\u10d0\u10d2\u10d6\u10d0\u10d5\u10dc\u10d8\u10da\u10d8\u10d0 {{to}}-\u10d6\u10d4","send.network_error":"\u10d9\u10d5\u10d0\u10dc\u10eb\u10d7\u10d0\u10dc \u10d3\u10d0\u10d9\u10d0\u10d5\u10e8\u10d8\u10e0\u10d4\u10d1\u10d0 \u10d5\u10d4\u10e0 \u10db\u10dd\u10ee\u10d4\u10e0\u10ee\u10d3\u10d0. \u10e8\u10d4\u10d0\u10db\u10dd\u10ec\u10db\u10d4\u10d7 \u10de\u10d0\u10e0\u10d0\u10db\u10d4\u10e2\u10e0\u10d4\u10d1\u10d8 > \u10d9\u10d5\u10d0\u10dc\u10eb\u10d4\u10d1\u10d8.","notif.tx_sent_title":"\u10e2\u10e0\u10d0\u10dc\u10d6\u10d0\u10e5\u10ea\u10d8\u10d0 \u10d2\u10d0\u10d2\u10d6\u10d0\u10d5\u10dc\u10d8\u10da\u10d8\u10d0","notif.tx_sent_body":"{{amount}} POH \u2192 {{to}}...","notif.received_title":"POH \u10db\u10d8\u10e6\u10d4\u10d1\u10e3\u10da\u10d8\u10d0","notif.received_body":"+{{delta}} POH {{addr}}-\u10d6\u10d4...","notif.created_title":"\u10e1\u10d0\u10e4\u10e3\u10da\u10d4 \u10e8\u10d4\u10d8\u10e5\u10db\u10dc\u10d0","notif.created_body":"\u10d0\u10ee\u10d0\u10da\u10d8 \u10db\u10d8\u10e1\u10d0\u10db\u10d0\u10e0\u10d7\u10d8: {{addr}}...","notif.imported_title":"\u10e1\u10d0\u10e4\u10e3\u10da\u10d4 \u10d8\u10db\u10de\u10dd\u10e0\u10e2\u10d8\u10e0\u10d4\u10d1\u10e3\u10da\u10d8\u10d0","notif.imported_body":"{{addr}}...",error:"\u10e8\u10d4\u10ea\u10d3\u10dd\u10db\u10d0","error.network":"\u10e5\u10e1\u10d4\u10da\u10d8\u10e1 \u10e8\u10d4\u10ea\u10d3\u10dd\u10db\u10d0","status.confirmed":"\u10d3\u10d0\u10d3\u10d0\u10e1\u10e2\u10e3\u10e0\u10d4\u10d1\u10e3\u10da\u10d8\u10d0"}}},964,[]);
